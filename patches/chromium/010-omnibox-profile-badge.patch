+void LocationBarView::UpdateProfileBadge() {
+  if (!profile_badge_label_) {
+    return;
+  }
+
+  auto environment = base::Environment::Create();
+  std::string profile_name_utf8;
+  if (!environment || !environment->GetVar(kBugmaxProfileNameEnv,
+                                           &profile_name_utf8) ||
+      profile_name_utf8.empty()) {
+    SetOmniboxAdjacentText(profile_badge_label_, std::u16string());
+    profile_badge_label_->SetTooltipText(std::u16string());
+    return;
+  }
+
+  std::u16string profile_name = base::UTF8ToUTF16(profile_name_utf8);
+  std::u16string badge_text = u"[";
+  badge_text += profile_name;
+  badge_text += u"]";
+  SetOmniboxAdjacentText(profile_badge_label_, badge_text);
+  profile_badge_label_->SetTooltipText(profile_name);
+}
